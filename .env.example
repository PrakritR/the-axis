# Axis stack — copy to `.env` in this folder (`the-axis/`). Do not commit real secrets.

# ── Axis Express API (Vite browser → same origin or localhost)
VITE_AXIS_API_URL=http://localhost:3001

# Vercel-style `/api` dev server (see vite.config.mjs). Default 3002 so Express can use 3001.
# LOCAL_API_PORT=3002

# Server-side proxy for tour handler etc. (no VITE_ prefix)
# AXIS_EXPRESS_API_URL=http://127.0.0.1:3001

# ── PostgreSQL (preferred single URL for express-api + migrate + seed)
DATABASE_URL=postgresql://postgres:Welcone56$@axis-db.cfk2w0y464lp.us-east-2.rds.amazonaws.com:5432/postgres?sslmode=require

# If not using DATABASE_URL:
# PGHOST=axis-db.cfk2w0y464lp.us-east-2.rds.amazonaws.com
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=YOUR_PASSWORD
# PGDATABASE=postgres
# PGSSL=true
# PGSSL_REJECT_UNAUTHORIZED=false

# ── Express API process
PORT=3001
JWT_SECRET=change-me-to-a-long-random-string

# Seed script (`cd express-api && npm run seed`)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=changeme123
# Align with /api/admin-portal-auth env login if you use both:
# AXIS_ADMIN_EMAIL=admin@example.com
# AXIS_ADMIN_PASSWORD=changeme123

# ── AWS S3 (property + application uploads)
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Optional alias used by some routes:
# S3_BUCKET_NAME=
# Optional CloudFront / public base (no trailing slash)
# AWS_S3_PUBLIC_BASE_URL=

# ── Optional app keys (Gemini, EmailJS, Supabase, Stripe) — see product docs
# VITE_GEMINI_API_KEY=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Portal inbox `Messages`: by default `sendMessage` does not write a timestamp (sorting uses Airtable created time). Set only if you have a writable Date field (not formula/Created time).
# VITE_AIRTABLE_MESSAGE_TIMESTAMP_FIELD=Timestamp
# VITE_AIRTABLE_MESSAGE_TIMESTAMP_FIELD=none

# Lease Drafts: checkbox field name for “allow resident to sign before paying move-in” (default shown). Omit from Airtable only if you do not use this feature.
# VITE_AIRTABLE_LEASE_SIGN_WITHOUT_PAY_FIELD=Allow Sign Without Move-In Pay
