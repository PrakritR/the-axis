# Axis stack — copy to `.env` in this folder (`the-axis/`). Do not commit real secrets.

# Vercel / serverless: POST /api/forms?action=tour|meeting reads AIRTABLE_TOKEN **or** VITE_AIRTABLE_TOKEN.
# If only VITE_AIRTABLE_TOKEN is set in the dashboard, that is enough for tour booking — duplicate as AIRTABLE_TOKEN if you prefer server-only names.

# ── Axis Express API (Vite browser → same origin or localhost)
VITE_AXIS_API_URL=http://localhost:3001

# Vercel-style `/api` dev server (see vite.config.mjs). Default 3002 so Express can use 3001.
# LOCAL_API_PORT=3002

# Server-side proxy for tour handler etc. (no VITE_ prefix)
# AXIS_EXPRESS_API_URL=http://127.0.0.1:3001

# ── PostgreSQL (preferred single URL for express-api + migrate + seed)
DATABASE_URL=postgresql://postgres:Welcone56$@axis-db.cfk2w0y464lp.us-east-2.rds.amazonaws.com:5432/postgres?sslmode=require

# If not using DATABASE_URL:
# PGHOST=axis-db.cfk2w0y464lp.us-east-2.rds.amazonaws.com
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=YOUR_PASSWORD
# PGDATABASE=postgres
# PGSSL=true
# PGSSL_REJECT_UNAUTHORIZED=false

# ── Express API process
PORT=3001
JWT_SECRET=change-me-to-a-long-random-string

# Seed script (`cd express-api && npm run seed`)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=changeme123
# Align with /api/admin-portal-auth env login if you use both:
# AXIS_ADMIN_EMAIL=admin@example.com
# AXIS_ADMIN_PASSWORD=changeme123

# ── AWS S3 (property + application uploads)
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Optional alias used by some routes:
# S3_BUCKET_NAME=
# Optional CloudFront / public base (no trailing slash)
# AWS_S3_PUBLIC_BASE_URL=

# ── Optional app keys (Gemini, EmailJS, Supabase, Stripe) — see product docs
# VITE_GEMINI_API_KEY=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# Server only: `public.app_users` sync / admin API (service role bypasses RLS — never expose to the browser).
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
# POST /api/sync-app-user validates the user JWT with the anon key (prefer server-only duplicate of the public anon key):
# SUPABASE_ANON_KEY=your-anon-key
# Admin portal: after Supabase sign-in, only these emails (comma-separated, case-insensitive) may continue. If unset, see hardcoded list in `frontend/src/lib/adminPortalAuthAllowlist.js`.
# VITE_ADMIN_PORTAL_ALLOWLIST=you@company.com

# Portal inbox `Messages`: by default `sendMessage` does not write a timestamp (sorting uses Airtable created time). Set only if you have a writable Date field (not formula/Created time).
# VITE_AIRTABLE_MESSAGE_TIMESTAMP_FIELD=Timestamp
# VITE_AIRTABLE_MESSAGE_TIMESTAMP_FIELD=none
#
# Messages `Subject` (single line text): inbox UI and thread titles read this field. Default column name is `Subject`. Set to `none` if your base has no Subject column (subjects are then merged into the message body only).
# VITE_AIRTABLE_MESSAGE_SUBJECT_FIELD=Subject
# VITE_AIRTABLE_MESSAGE_SUBJECT_FIELD=none

# Lease Drafts: checkbox field name for “allow resident to sign before paying move-in” (default shown). Omit from Airtable only if you do not use this feature.
# Lease Drafts checkbox: resident may sign before move-in charges (see docs).
# Optional Lease Drafts fields for manager/landlord counter-signature (long text recommended for image data URL).
# VITE_AIRTABLE_LEASE_MANAGER_SIGNATURE_TEXT_FIELD=Manager Signature Text
# VITE_AIRTABLE_LEASE_MANAGER_SIGNATURE_AT_FIELD=Manager Signed At
# VITE_AIRTABLE_LEASE_MANAGER_SIGNATURE_IMAGE_FIELD=Manager Signature Image
# VITE_AIRTABLE_LEASE_SIGN_WITHOUT_PAY_FIELD=Allow Sign Without Move-In Pay
# Server-only duplicate (Vercel /api/portal) if you prefer not to expose VITE_* on the server:
# AIRTABLE_LEASE_SIGN_WITHOUT_PAY_FIELD=Allow Sign Without Move-In Pay

# Scheduling table name on the core base (tours, meetings, work-order calendar rows). Default `Scheduling`.
# AIRTABLE_SCHEDULING_TABLE=Scheduling
# VITE_AIRTABLE_SCHEDULING_TABLE=Scheduling

# Scheduling table: long-text column for tour/meeting guest notes from Contact + API. Default `Message` (see docs/airtable-portal-schema.txt). Use `Notes` only if that is your actual field name.
# AIRTABLE_SCHEDULING_NOTES_FIELD=Message

# --- Optional: put BOTH availability tables in a different base than Properties/Scheduling ---
# Same personal access token must have access to this base.
# AIRTABLE_AVAILABILITY_BASE_ID=appXXXXXXXXXXXXXX
# VITE_AIRTABLE_AVAILABILITY_BASE_ID=appXXXXXXXXXXXXXX

# --- Manager tour availability (Airtable) — per-property + recurring weekly blocks ---
# Create a `Manager Availability` table (or set MANAGER_AVAILABILITY_TABLE) with fields documented in docs/AIRTABLE_SETUP_PROMPT.md.
# Frontend (Manager portal): set false/none/0/off only if you intentionally skip the table.
VITE_USE_MANAGER_AVAILABILITY_TABLE=true
# MANAGER_AVAILABILITY_TABLE=Manager Availability
# AIRTABLE_MANAGER_AVAILABILITY_TABLE=Manager Availability
# If Property Record ID / Manager Record ID are Airtable linked-record fields (not single-line text), set true so creates send [rec…] arrays.
# VITE_MANAGER_AVAILABILITY_LINK_FIELD_IDS=true

# --- Admin meeting availability (separate table from manager tours) ---
# When this table name differs from the manager table, `/api/meeting` and the admin calendar
# read/write ONLY this table for open meeting slots; manager tour slots use the manager table only.
# Same field schema as Manager Availability; rows use empty Property Name + Property Record ID (global admin).
# AIRTABLE_ADMIN_MEETING_AVAILABILITY_TABLE=Admin Meeting Availability
# VITE_AIRTABLE_ADMIN_MEETING_AVAILABILITY_TABLE=Admin Meeting Availability
# MANAGER_AVAIL_FIELD_PROPERTY_NAME=Property Name
# MANAGER_AVAIL_FIELD_PROPERTY_RECORD_ID=Property Record ID
# MANAGER_AVAIL_FIELD_MANAGER_EMAIL=Manager Email
# MANAGER_AVAIL_FIELD_MANAGER_RECORD_ID=Manager Record ID
# MANAGER_AVAIL_FIELD_DATE=Date
# MANAGER_AVAIL_FIELD_WEEKDAY=Weekday
# MANAGER_AVAIL_FIELD_START_TIME=Start Time
# MANAGER_AVAIL_FIELD_END_TIME=End Time
# Optional single-select on Manager Availability: one Airtable row per 30-minute slot (labels like 7:00am-7:30am). See docs §2.7.
# MANAGER_AVAIL_FIELD_TIME_SLOT=Time Slot
# MANAGER_AVAIL_FIELD_STATUS=Status
# MANAGER_AVAIL_FIELD_IS_RECURRING=Is Recurring
# MANAGER_AVAIL_FIELD_ACTIVE=Active
# MANAGER_AVAIL_FIELD_TIMEZONE=Timezone
# MANAGER_AVAIL_FIELD_SOURCE=Source
# MANAGER_AVAIL_FIELD_RECURRENCE_START=Recurrence Start
# Vite overrides (same keys with VITE_ prefix) are supported for browser-side reads.

# --- Resident Payments ---
# Payments table: linked-record column that points at the resident profile row. Default `Resident`. If your base uses e.g. `Resident Profile`, set the exact field name so portal queries and new payment rows match.
# VITE_AIRTABLE_PAYMENTS_RESIDENT_LINK_FIELD=Resident Profile
# Checkbox on Residents: resident chose "hold room" before signing lease (move-in path). If your column name differs from the built-in fallbacks, set this to the exact Airtable field name.
# VITE_RESIDENT_ROOM_HOLD_WITHOUT_LEASE_FIELD=Room Hold Without Lease
# If that field is Single select (not Checkbox), set comma-separated PATCH values that match your option labels exactly (tried in order). Example: VITE_RESIDENT_ROOM_HOLD_WITHOUT_LEASE_TRUE_VALUES=Hold only
# VITE_RESIDENT_ROOM_HOLD_WITHOUT_LEASE_TRUE_VALUES=
# VITE_RESIDENT_ROOM_HOLD_WITHOUT_LEASE_FALSE_VALUES=
# Default room hold when no Airtable row yet (Resident portal). Set 0 to hide.
# VITE_ROOM_HOLD_FEE_USD=100
# Months of recurring rent + utilities rows shown after move-in (synthetic until Airtable rows exist).
# VITE_PAYMENT_SCHEDULE_HORIZON_MONTHS=12
# After loading Payments, PATCH Airtable Status to Paid / Overdue / Due Soon / Unpaid when it lags math. Set false to disable.
# VITE_AUTO_SYNC_PAYMENT_STATUS=true

# --- Stripe (Apply application fee, Resident checkout, billing portal, manager tiers) ---
# Publishable key is bundled in the frontend build — use restricted/test keys in dev.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Server-only (never prefix with VITE_): used by /api/stripe, webhooks, and portal sync.
# STRIPE_SECRET_KEY=sk_test_...
# Signing secret from Stripe Dashboard → Developers → Webhooks → your endpoint, or from Stripe CLI when testing locally.
# STRIPE_WEBHOOK_SECRET=whsec_...
# Production webhook URL (Vercel): https://<your-host>/api/stripe-webhook — event: checkout.session.completed
# Canonical path (stub → full logic): https://<your-host>/api/stripe/webhook — use this in Stripe Dashboard when migrated.
# Local webhooks: install Stripe CLI (https://stripe.com/docs/stripe-cli), run `npm run dev:api` (default port 3001), then:
#   stripe listen --forward-to http://127.0.0.1:3001/api/stripe-webhook
# Paste the CLI “webhook signing secret” into STRIPE_WEBHOOK_SECRET for that shell session.
# Optional (Cursor only): Stripe Marketplace plugin + https://docs.stripe.com/mcp — helps the agent inspect Stripe; not required for the app to run. Never commit live secret keys into the repo or MCP config.

# Optional: second Checkout line item on /api/stripe (resident payments + application fee) so card totals include a service / processing fee.
# Omit both to keep a single line (no add-on). You can set flat USD, percent of subtotal, or both (applied as percent of base then + flat).
# STRIPE_CARD_SERVICE_FEE_USD=2.75
# STRIPE_CARD_SERVICE_FEE_PERCENT=3
# STRIPE_CARD_SERVICE_FEE_LABEL=Card processing & service fee

# ── Manager Add Property wizard (native Properties columns vs Other Info meta) ──
# When true (default), the wizard writes `Room N Rent`, `Room N Availability`, etc. If your base only has
# columns through e.g. Room 9, set the limit so extra rooms store rent only in listing meta (avoids UNKNOWN_FIELD_NAME).
# VITE_AIRTABLE_PROPERTY_ROOM_NATIVE_COLUMN_LIMIT=9
# Set false to skip all native room columns and keep rent/availability only in Other Info JSON.
# VITE_AIRTABLE_WRITE_ROOM_COLUMNS=false
# Exact Properties **attachment** column for listing photos (Add Property uploads + `axis-r*` / `axis-b*` / etc.).
# Default is `Photos`. Set if your base uses e.g. `Images`.
# VITE_AIRTABLE_PROPERTY_PHOTOS_FIELD=Images

# Stripe: USD charged for applicant pre-submit application fee (`category: application_fee`).
# Server enforces this amount (client `amount` is ignored). Omit to use repo default **50** USD (see `shared/stripe-application-fee-defaults.js`).
# Values above 0 but below 0.50 are clamped to 0.50 (Stripe USD minimum). Use 0 for no card fee (promo / internal).
# STRIPE_APPLICATION_FEE_USD=50
# Frontend display + checkout request (should match server). Omit to match server default when a fee applies.
# VITE_STRIPE_APPLICATION_FEE_USD=50
# Server: only set if your Applications table has this exact column (number/currency). If unset, the payment-draft create omits it (avoids Airtable INVALID_VALUE / unknown field).
# AIRTABLE_APPLICATION_FEE_DUE_USD_FIELD=Application Fee Due (USD)
#
# If Applications lives in a different Airtable base than Properties, set BOTH (same values) so /api/portal application-* handlers match the UI token’s base. Omit to use VITE_AIRTABLE_BASE_ID / AIRTABLE_BASE_ID.
# The server PAT (AIRTABLE_TOKEN or VITE_AIRTABLE_TOKEN) must have data.records:read + data.records:write on that base.
# AIRTABLE_APPLICATIONS_BASE_ID=appXXXXXXXXXXXXXX
# AIRTABLE_APPLICATIONS_TABLE=Applications

# --- Applications table (Apply.jsx): optional columns that mirror group + ranked rooms ---
# Field names must match Airtable exactly. Omit all of these to keep only Additional Notes + Room Number.
# Checkbox: true when applicant chose “applying as a group”, false otherwise.
# VITE_AIRTABLE_APPLICATION_GROUP_CHECKBOX_FIELD=group(yes/no)
# Text: expected headcount when the applicant is the first in the group (left empty for joiners).
# VITE_AIRTABLE_APPLICATION_GROUP_SIZE_FIELD=number in group
# Plain single-line text for the app-generated AXISGRP-… id (not a formula column — the API cannot write formulas).
# VITE_AIRTABLE_APPLICATION_AXIS_GROUP_ID_FIELD=Axis Group ID
# Optional mirrors for 2nd/3rd room choices (1st choice stays in Room Number).
# Optional: override Airtable Applications column names (defaults match Apply form + manager approval).
# VITE_AIRTABLE_APPLICATION_ROOM_CHOICE_2_FIELD=2nd choice (optional)
# VITE_AIRTABLE_APPLICATION_ROOM_CHOICE_3_FIELD=3rd choice (optional)
# Single line text field — manager-assigned room on approve (used for lease draft + pricing).
# Manager-assigned unit on Applications (resident portal "Unit Number" + lease drafts use this only — not the applicant’s 1st choice).
# Repo default column name is Approved Unit Room; older bases may use Approved Room.
# VITE_AIRTABLE_APPLICATION_APPROVED_ROOM_FIELD=Approved Unit Room
# Server (portal API) can set the same without VITE_ prefix, e.g. AIRTABLE_APPLICATION_APPROVED_ROOM_FIELD=Approved Room
