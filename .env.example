# Copy this file to .env and fill in your values
# WARNING: All VITE_ variables are bundled into the client-side build and visible to users.
# For production, proxy API requests through a backend instead.

# Set to true (or 1/yes) to show a full-site maintenance page for every route. Omit or set false to serve the normal app.
# VITE_MAINTENANCE_MODE=true

# Google Gemini API key — get from https://aistudio.google.com
# Create a key in a NEW project to get a fresh free-tier quota
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic — server-side lease generation for the manager portal
# Add this to your local `.env` and to Vercel project environment variables.
# Do not prefix with VITE_ or it will be exposed to the browser bundle.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# /admin — site owner sign-in (server-only; never use VITE_*). Required for owner login at /admin.
# Local: ensure the API dev server proxies /api (see vite.config.mjs LOCAL_API_PORT).
# SITE_OWNER_EMAIL=you@example.com
# SITE_OWNER_PASSWORD=use-a-strong-secret

# /admin — Sentinel developer login (server-only). Defaults: username prakrit, password Welcome56$ (also accepts Welcone56$).
# Override in production — never commit real secrets.
# AXIS_DEVELOPER_USERNAME=prakrit
# AXIS_DEVELOPER_PASSWORD=Welcome56$

# EmailJS credentials — get from https://www.emailjs.com
# 1. Add a Gmail service → copy Service ID
# 2. Create an email template → copy Template ID
# 3. Account → API Keys → copy Public Key
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
# Optional dedicated template for lease signing invites sent by `/api/send-lease-invite`
VITE_EMAILJS_LEASE_TEMPLATE=your_emailjs_lease_template_id

# Supabase — Resident Portal auth and photo storage
# Get from: Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Supabase Storage bucket name for resident photos (default: resident-uploads)
VITE_SUPABASE_STORAGE_BUCKET=resident-uploads

# Airtable — Shared API token (used by both bases below)
# Get from: airtable.com → Account → Developer Hub → Personal access tokens
# Scopes needed: data.records:read, data.records:write on both bases
VITE_AIRTABLE_TOKEN=your_airtable_personal_access_token
# Server-only duplicate (recommended on Vercel): API routes may not see VITE_* at runtime.
# AIRTABLE_TOKEN=your_airtable_personal_access_token

# Airtable — Resident Portal base (Work Orders, Messages, Residents, Announcements, Payments)
VITE_AIRTABLE_BASE_ID=appol57LKtMKaQ75T
#
# Properties table: optional number field "Application Fee" (USD per applicant) overrides the marketing default
# on /apply — the Apply page loads fees from GET /api/forms?action=tour when the Airtable property Name matches
# the listing name on the form exactly.
#
# Manager portal — "Add a house" wizard also creates linked rows in a Rooms table (same base).
# 1) Create table "Rooms" (or set VITE_AIRTABLE_ROOMS_TABLE) with a link field to Properties (default field name: Property).
# 2) Add columns matching the defaults below, or override names with these env vars:
#    VITE_AIRTABLE_ROOM_LINK_FIELD=Property
#    VITE_AIRTABLE_ROOM_NUMBER_FIELD=Room Number
#    VITE_AIRTABLE_ROOM_RENT_FIELD=Monthly Rent
#    VITE_AIRTABLE_ROOM_FURNISHED_FIELD=Furnished          # checkbox — true if partially or fully furnished
#    VITE_AIRTABLE_ROOM_FURNISHING_DETAIL_FIELD=Furnishing Detail
#    VITE_AIRTABLE_ROOM_FLOOR_FIELD=Floor
#    VITE_AIRTABLE_ROOM_BATHROOM_FIELD=Bathroom Type
#    VITE_AIRTABLE_ROOM_SQFT_FIELD=Square Feet
#    VITE_AIRTABLE_ROOM_BED_FIELD=Bed Size
#    VITE_AIRTABLE_ROOM_DESK_FIELD=Desk Included          # checkbox
#    VITE_AIRTABLE_ROOM_AC_FIELD=AC                       # checkbox
#    VITE_AIRTABLE_ROOM_STORAGE_FIELD=Closet / Storage
#    VITE_AIRTABLE_ROOM_WINDOWS_FIELD=Windows / Natural Light
#    VITE_AIRTABLE_ROOM_NOTES_FIELD=Room Notes
#    VITE_AIRTABLE_ROOM_AVAILABILITY_FIELD=Availability
#    VITE_AIRTABLE_ROOM_KITCHEN_INCLUDED_FIELD=Kitchen Included   # in-room kitchenette / mini-kitchen list (long text)
#    VITE_AIRTABLE_ROOM_LAUNDRY_FIELD=Laundry Access              # per-room laundry type + who shares (long text)
#    VITE_AIRTABLE_ROOM_PARKING_FIELD=Parking Access               # per-room parking summary (long text)
# VITE_AIRTABLE_ROOMS_TABLE=Rooms
# Optional: only if your Payments table lives in a different base than VITE_AIRTABLE_BASE_ID (token must have access to both).
# VITE_AIRTABLE_PAYMENTS_BASE_ID=appXXXXXXXXXXXXXX

# Portal inbox (Management ↔ Admin, Site manager ↔ Admin) — same Messages table as work-order threads.
# 1) Add text field "Thread Key" and single select "Channel" with option internal_mgmt_admin (or override names below).
# 2) Allow Work Order to be empty on Messages rows created from these threads.
# 3) Optional: create an Airtable Form on Messages and paste its share URL here (prefill_* will be appended in-app).
# VITE_AIRTABLE_MESSAGE_THREAD_KEY_FIELD=Thread Key
# VITE_AIRTABLE_MESSAGE_CHANNEL_FIELD=Channel
# VITE_AIRTABLE_PORTAL_INBOX_FORM_URL=https://airtable.com/appXXXX/shrXXXX

# Airtable — Applications base (Apply page form: Applications, Co-Signers tables)
VITE_AIRTABLE_APPLICATIONS_BASE_ID=appNBX2inqfJMyqYV
VITE_AIRTABLE_APPLICATIONS_TABLE=Applications
VITE_AIRTABLE_COAPPLICANTS_TABLE=Co-Signers

# Stripe
# Publishable key is safe for the client. Secret key must stay server-side only.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Recurring subscription Price ID used for manager portal onboarding.
# Create a monthly recurring price in Stripe, then paste the price id here.
STRIPE_MANAGER_PRICE_ID=price_your_manager_monthly_price_id
# Optional: store each resident's Stripe customer ID in Airtable field:
# `Stripe Customer ID`

# Production: set for canonical URLs / sitemap. Local dev defaults to http://localhost:5174.
# VITE_SITE_URL=https://your-live-domain.com
# Optional — only for getHousingSiteOrigin() when window is unavailable (e.g. absolute links in emails). Nav uses same-origin paths.
# VITE_HOUSING_SITE_URL=https://your-live-domain.com
# Optional housing home path for in-app <Link> (default /). Full https URLs are reduced to pathname only so Explore properties stays on the current origin in dev.
# VITE_HOUSING_EXPLORE_PATH=/
